# Operating system files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editors and local workspace state
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
*.swp
*.swo
*~

# Environment and secrets
.env
.env.*
!.env.example
*.local

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python packaging and coverage
dist/
build/
*.egg-info/
.eggs/
pip-wheel-metadata/
htmlcov/
.coverage
.coverage.*
coverage.xml

# Django local runtime data
db.sqlite3
db.sqlite3-*
staticfiles/
media/*
!media/.gitkeep
!media/receipts/
media/receipts/*
!media/receipts/.gitkeep

# Local logs and temporary files
*.log
logs/
tmp/
tmp*/
.tmp/
.desktop-data-test/

# Node and Electron dependencies
node_modules/
electron_app/node_modules/

# Electron and desktop build artifacts
electron_app/dist/
electron_app/out/
electron_app/release/
electron_app/backend/*
